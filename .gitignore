!frontend/.env

# Node
node_modules/
dist/
.DS_Store
coverage/
.vscode/

# Claude Code (local tool config — may contain dev credentials)
.claude/

# SQLite databases (test artefacts)
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.backup-*
*.db.backup-*-wal
*.db.backup-*-shm

# Cost control app — build artefacts and binaries (regenerable from source)
app/build/
app/dist/
*.exe
*.exe.old

# OneDrive sync ghost files
.fuse_hidden*

